<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required for "Sign in with Apple". The matching capability is enabled
	     on the App ID in the Apple Developer portal. -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!-- NOTE: no aps-environment here. Glint's daily notifications are LOCAL
	     (scheduled on-device) and do NOT need the Push Notifications
	     capability. Only add aps-environment if you later use remote push
	     (FCM) or iOS phone-auth — and enable Push on the App ID first. -->
</dict>
</plist>
